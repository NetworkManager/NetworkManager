"    wifi:         ssid <SSID>\n"
"                  [mac <MAC address>]\n"
"                  [cloned-mac <cloned MAC address>]\n"
"                  [mtu <MTU>]\n"
"                  [mode infrastructure|ap|adhoc]\n"
"\n"
"    wimax:        [mac <MAC address>]\n"
"                  [nsp <NSP>]\n"
